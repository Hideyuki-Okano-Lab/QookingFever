Bootstrap: docker
From: ubuntu:22.04

%labels
    Author {{cookiecutter.author_name}}
    Version 1.0.0
    Project_Name {{cookiecutter.project_name}}
    Description "{{cookiecutter.description}}"

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:$PATH

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get upgrade -y
    apt-get install -y --no-install-recommends \
        build-essential \
        wget \
        curl \
        unzip \
        pigz \
        samtools \
        ca-certificates \
        jq

    wget -qO /usr/local/bin/fastp http://opengene.org/fastp/fastp
    chmod +x /usr/local/bin/fastp

    cd /tmp
    STAR_URL=$(curl -sL https://api.github.com/repos/alexdobin/STAR/releases/latest | jq -r '.assets[] | select(.name | endswith(".zip")) | .browser_download_url' | head -n 1)
    wget -qO star_latest.zip "$STAR_URL"
    unzip -q star_latest.zip
    find . -type f -name "STAR" -path "*/Linux_x86_64_static/*" -exec cp {} /usr/local/bin/ \;

    SUBREAD_URL=$(curl -sL "https://sourceforge.net/projects/subread/rss?path=/" | grep -oP 'https://sourceforge.net/projects/subread/files/subread-[0-9.]+/subread-[0-9.]+-Linux-x86_64.tar.gz/download' | head -n 1)
    wget -qO subread_latest.tar.gz "$SUBREAD_URL"
    mkdir subread_extracted
    tar xzf subread_latest.tar.gz -C subread_extracted --strip-components=1
    cp subread_extracted/bin/featureCounts /usr/local/bin/

    rm -f /tmp/star_latest.zip /tmp/subread_latest.tar.gz
    rm -rf /tmp/subread_extracted
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec "$@"

%test
    echo "Checking installed tools..."
    samtools --version | head -n 1
    pigz --version
    wget --version | head -n 1
    fastp --version 2>&1
    STAR --version
    featureCounts -v 2>&1 | grep "featureCounts"

%help
    {{cookiecutter.project_name}} Container Engine
    {{"-" * cookiecutter.project_name|length}}-----------------
    This container encapsulates all necessary tools for the QookFast pipeline in {{cookiecutter.project_name}}.
    Usage:
        apptainer exec {{cookiecutter.__Project_Slug.lower()}}.sif [command]
