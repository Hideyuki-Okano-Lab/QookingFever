{
    "project_name": "ALS_RNAseq",
    "__Project_Slug": "{{ cookiecutter.project_name.replace(' ', '_').replace('-', '_').replace('/', '_') }}",
    "description": "Write the goal/purpose of this project here",
    "author_name": "Your Name",
    "email": "example@example.com",
    "_extensions": ["jinja2_time.TimeExtension"],
    "__timestamp": "{% now 'local', '%Y-%m-%d %H:%M:%S' %}",
    "species": ["Homo_sapiens", "Mus_musculus"],
    "__ref": "{{ 'GRCh38' if cookiecutter.species == 'Homo_sapiens' else 'GRCm39' }}",
    "read_length": 150,
    "read_type": ["single_end", "pair_end"],
    "threads": 8,
    "strand": ["unstranded", "stranded", "rev-stranded"]
}
